# ==========================================
# База данных (PostgreSQL)
# ==========================================
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql://travel_user:password@localhost:5432/travel_planner

# ==========================================
# Кэширование и очереди (Redis)
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# Авторизация и настройки приложения
# ==========================================
JWT_SECRET=
JWT_EXPIRES_IN=7d
FRONTEND_URL=

# ==========================================
# AI модели (LLM) - генерация маршрутов
# ==========================================
OPENAI_API_KEY=sk-or-...
FF_PLANNER_V2_ENABLED=false
FF_PLANNER_V2_CONTRACT_FIELDS=false
FF_PLANNER_SSE_ENABLED=false
FF_INTENT_ROUTER_V2=false
FF_POLICY_CALC_V2=false
FF_LOGICAL_ID_FILTER_V2=false
FF_VECTOR_PREFILTER_REDIS=false
FF_DETERMINISTIC_PLANNER_V2=false
FF_MASS_COLLECTION_V2=false
FF_YANDEX_BATCH_REFINEMENT=false
AI_VECTOR_TOPK=200
YANDEX_BATCH_SIZE=24
YANDEX_BATCH_TIMEOUT_MS=8000

# ==========================================
# Сервисы Яндекс (LLM, Карты, Геокодинг)
# ==========================================
YANDEX_GPT_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MAPS_API_KEY=
NEXT_PUBLIC_YANDEX_TILES_API_KEY=

# ==========================================
# Геосервисы и Маршрутизация (Geocoding, OSRM)
# ==========================================
LOCATIONIQ_API_KEY= pk.cd...
GEOAPIFY_API_KEY=
ORS_API_KEY=

# ==========================================
# Dadata (Подсказки и валидация адресов)
# ==========================================
DADATA_API_KEY=
DADATA_SECRET_KEY=
